{
  "schema": "gentle.workflow_example.v1",
  "id": "gene_panel_isoform_protein_gel_ensembl",
  "title": "Gene-panel isoform protein gel from Ensembl (online)",
  "summary": "Fetches PATZ1, TP73, TP53, TP63, SP1, and BACH2 from Ensembl, derives protein-coding transcript products, and renders one 1D protein molecular-weight gel with one column per gene and protein ladders at the sides.",
  "test_mode": "online",
  "required_files": [],
  "tags": [
    "ensembl",
    "protein",
    "isoform",
    "gel",
    "gene-panel",
    "online",
    "clawbio"
  ],
  "workflow": {
    "run_id": "example_gene_panel_isoform_protein_gel_ensembl",
    "ops": [
      {
        "FetchEnsemblGene": {
          "query": "PATZ1",
          "species": "homo_sapiens",
          "entry_id": "patz1_ensembl_gene"
        }
      },
      {
        "ImportEnsemblGeneSequence": {
          "entry_id": "patz1_ensembl_gene",
          "output_id": "patz1_ensembl_locus"
        }
      },
      {
        "DeriveProteinSequences": {
          "seq_id": "patz1_ensembl_locus",
          "feature_query": {
            "seq_id": "patz1_ensembl_locus",
            "include_source": false,
            "include_qualifiers": false,
            "kind_in": [
              "mRNA"
            ],
            "kind_not_in": [],
            "range_relation": "overlap",
            "strand": "any",
            "qualifier_filters": [
              {
                "key": "biotype",
                "value_contains": "protein_coding",
                "value_regex": "^protein_coding$",
                "case_sensitive": true
              }
            ],
            "sort_by": "feature_id",
            "descending": false,
            "offset": 0
          },
          "output_prefix": "patz1_ensembl_protein",
          "report_id": "patz1_ensembl_protein_gel"
        }
      },
      {
        "FetchEnsemblGene": {
          "query": "TP73",
          "species": "homo_sapiens",
          "entry_id": "tp73_ensembl_gene"
        }
