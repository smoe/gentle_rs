{
  "schema": "gentle.workflow_example.v1",
  "id": "pcr_selection_batch_primer_pairs_offline",
  "title": "PCR selection-first batch primer design on TP73-AS2 promoter context (offline)",
  "summary": "Loads local TP73 locus sequence, materializes two TP73-AS2 promoter-window ROI copy artifacts, and designs primer-pair reports for both regions.",
  "test_mode": "always",
  "required_files": [
    "test_files/tp73.ncbi.gb"
  ],
  "tags": [
    "tutorial",
    "pcr",
    "primer",
    "tp73",
    "promoter",
    "extract_region",
    "offline"
  ],
  "workflow": {
    "run_id": "example_pcr_selection_batch_primer_pairs_offline",
    "ops": [
      {
        "LoadFile": {
          "path": "test_files/tp73.ncbi.gb",
          "as_id": "tp73_locus"
        }
      },
      {
        "ExtractRegion": {
          "input": "tp73_locus",
          "from": 61720,
          "to": 62120,
          "output_id": "tp73_as2_promoter_roi_1"
        }
      },
      {
        "ExtractRegion": {
          "input": "tp73_locus",
          "from": 61940,
          "to": 62340,
          "output_id": "tp73_as2_promoter_roi_2"
        }
      },
      {
        "DesignPrimerPairs": {
          "template": "tp73_locus",
          "roi_start_0based": 61720,
          "roi_end_0based": 62120,
          "forward": {
            "min_length": 18,
            "max_length": 26,
            "location_0based": 61760,
            "min_tm_c": 35.0,
            "max_tm_c": 90.0,
            "min_gc_fraction": 0.0,
            "max_gc_fraction": 1.0,
            "max_anneal_hits": 100000
          },
          "reverse": {
            "min_length": 18,
            "max_length": 26,
            "location_0based": 62080,
            "min_tm_c": 35.0,
            "max_tm_c": 90.0,
            "min_gc_fraction": 0.0,
            "max_gc_fraction": 1.0,
            "max_anneal_hits": 100000
          },
          "min_amplicon_bp": 90,
          "max_amplicon_bp": 400,
          "max_tm_delta_c": 15.0,
          "max_pairs": 50,
          "report_id": "tp73_as2_promoter_batch_r01"
        }
      },
      {
        "DesignPrimerPairs": {
          "template": "tp73_locus",
          "roi_start_0based": 61940,
          "roi_end_0based": 62340,
          "forward": {
            "min_length": 18,
            "max_length": 26,
            "location_0based": 61980,
            "min_tm_c": 35.0,
            "max_tm_c": 90.0,
            "min_gc_fraction": 0.0,
            "max_gc_fraction": 1.0,
            "max_anneal_hits": 100000
          },
          "reverse": {
            "min_length": 18,
            "max_length": 26,
            "location_0based": 62300,
            "min_tm_c": 35.0,
            "max_tm_c": 90.0,
            "min_gc_fraction": 0.0,
            "max_gc_fraction": 1.0,
            "max_anneal_hits": 100000
          },
          "min_amplicon_bp": 90,
          "max_amplicon_bp": 400,
          "max_tm_delta_c": 15.0,
          "max_pairs": 50,
          "report_id": "tp73_as2_promoter_batch_r02"
        }
      }
    ]
  }
}
