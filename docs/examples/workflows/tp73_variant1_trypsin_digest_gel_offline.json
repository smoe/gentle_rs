{
  "schema": "gentle.workflow_example.v1",
  "id": "tp73_variant1_trypsin_digest_gel_offline",
  "title": "TP73 variant 1 trypsin digest gel (offline)",
  "summary": "Loads the bundled TP73 GenBank asset, derives transcript-native TP73 variant 1 protein, and renders a trypsin peptide digest gel for ClawBio-ready graphical inspection.",
  "test_mode": "always",
  "required_files": [
    "test_files/tp73.ncbi.gb"
  ],
  "tags": [
    "tp73",
    "protein",
    "protease",
    "trypsin",
    "digest",
    "gel",
    "offline",
    "clawbio"
  ],
  "workflow": {
    "run_id": "example_tp73_variant1_trypsin_digest_gel_offline",
    "ops": [
      {
        "LoadFile": {
          "path": "test_files/tp73.ncbi.gb",
          "as_id": "tp73_locus"
        }
      },
      {
        "DeriveProteinSequences": {
          "seq_id": "tp73_locus",
          "feature_query": {
            "seq_id": "tp73_locus",
            "include_source": false,
            "include_qualifiers": false,
            "kind_in": [
              "mRNA"
            ],
            "kind_not_in": [],
            "range_relation": "overlap",
            "strand": "any",
            "label_regex": "^tumor protein p73, transcript variant 1$",
            "qualifier_filters": [
              {
                "key": "gene",
                "value_contains": "TP73",
                "value_regex": "^TP73$",
                "case_sensitive": true
              },
              {
                "key": "transcript_id",
                "value_contains": "NM_",
                "value_regex": "^NM_",
                "case_sensitive": true
              }
            ],
            "sort_by": "feature_id",
            "descending": false,
            "offset": 0
          },
          "output_prefix": "tp73_variant1_protein",
          "report_id": "tp73_variant1_protein"
        }
      },
      {
        "RenderProteaseDigestGelSvg": {
          "report_id": "tp73_variant1_protein",
          "proteases": [
            "Trypsin"
          ],
          "path": "exports/tp73_variant1_trypsin_digest_gel.svg",
          "min_length_aa": 20,
          "ladders": [
            "Protein Ladder 10-100 kDa"
          ]
        }
      }
    ]
  }
}
