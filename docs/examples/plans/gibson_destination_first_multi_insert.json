{
  "schema": "gentle.gibson_assembly_plan.v1",
  "id": "gibson_destination_first_multi_insert",
  "title": "Destination-first Gibson assembly plan (two inserts)",
  "summary": "Opens a destination vector at a defined site, keeps the destination-derived left and right terminal junctions distinct, and inserts two fragments in a defined order with one internal fragment-fragment junction.",
  "destination": {
    "seq_id": "destination_vector",
    "topology_before_opening": "circular",
    "opening": {
      "mode": "defined_site",
      "label": "vector insertion window",
      "left_end_id": "dest_left",
      "right_end_id": "dest_right",
      "uniqueness_requirement": "must_be_unambiguous"
    }
  },
  "product": {
    "topology": "circular",
    "output_id_hint": "destination_with_insert_x_insert_y"
  },
  "fragments": [
    {
      "id": "insert_x",
      "seq_id": "insert_x_amplicon",
      "role": "insert",
      "orientation": "forward",
      "left_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_left"
      },
      "right_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_xy"
      }
    },
    {
      "id": "insert_y",
      "seq_id": "insert_y_amplicon",
      "role": "insert",
      "orientation": "forward",
      "left_end_strategy": {
        "mode": "native_overlap",
        "target_junction_id": "junction_xy"
      },
      "right_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_right"
      }
    }
  ],
  "assembly_order": [
    {
      "kind": "destination_end",
      "id": "dest_left"
    },
    {
      "kind": "fragment",
      "id": "insert_x"
    },
    {
      "kind": "fragment",
      "id": "insert_y"
    },
    {
      "kind": "destination_end",
      "id": "dest_right"
    }
  ],
  "junctions": [
    {
      "id": "junction_left",
      "left_member": {
        "kind": "destination_end",
        "id": "dest_left"
      },
      "right_member": {
        "kind": "fragment",
        "id": "insert_x"
      },
      "required_overlap_bp": 30,
      "overlap_source": "derive_from_destination_left_flank",
      "distinct_from": [
        "junction_right"
      ]
    },
    {
      "id": "junction_xy",
      "left_member": {
        "kind": "fragment",
        "id": "insert_x"
      },
      "right_member": {
        "kind": "fragment",
        "id": "insert_y"
      },
      "required_overlap_bp": 28,
      "overlap_source": "derive_from_adjacent_fragment_ends",
      "distinct_from": []
    },
    {
      "id": "junction_right",
      "left_member": {
        "kind": "fragment",
        "id": "insert_y"
      },
      "right_member": {
        "kind": "destination_end",
        "id": "dest_right"
      },
      "required_overlap_bp": 30,
      "overlap_source": "derive_from_destination_right_flank",
      "distinct_from": [
        "junction_left"
      ]
    }
  ],
  "validation_policy": {
    "require_unambiguous_destination_opening": true,
    "require_distinct_terminal_junctions": true,
    "adjacency_overlap_mismatch": "error",
    "design_targets": {
      "overlap_bp_min": 20,
      "overlap_bp_max": 40,
      "minimum_overlap_tm_celsius": 60.0
    },
    "uniqueness_checks": {
      "destination_context": "warn",
      "participating_fragments": "warn",
      "reference_contexts": [
        {
          "reference_id": "host_genome",
          "severity": "warn"
        }
      ]
    }
  },
  "derived_design": {
    "junction_overlaps": [
      {
        "junction_id": "junction_left",
        "sequence": null,
        "sequence_source_note": "Derived from the destination left flank at planning time."
      },
      {
        "junction_id": "junction_xy",
        "sequence": null,
        "sequence_source_note": "Derived from the adjacent insert termini or by adaptation if native overlap is absent."
      },
      {
        "junction_id": "junction_right",
        "sequence": null,
        "sequence_source_note": "Derived from the destination right flank at planning time."
      }
    ],
    "primer_tail_suggestions": [
      {
        "fragment_id": "insert_x",
        "primer": "forward",
        "adds_junction_id": "junction_left",
        "tail_bp": 30,
        "tail_source_note": "Use the destination left flank as the 5' primer tail."
      },
      {
        "fragment_id": "insert_x",
        "primer": "reverse",
        "adds_junction_id": "junction_xy",
        "tail_bp": 28,
        "tail_source_note": "Add the insert_y-adjacent internal overlap to the reverse primer if insert_x does not already end with it."
      },
      {
        "fragment_id": "insert_y",
        "primer": "reverse",
        "adds_junction_id": "junction_right",
        "tail_bp": 30,
        "tail_source_note": "Use the reverse complement of the destination right flank as the 5' primer tail."
      }
    ],
    "notes": [
      "The internal fragment-fragment junction is allowed to differ in length from the terminal destination-derived junctions.",
      "Multi-fragment cartoons can be derived from the same adjacency chain by rendering one event sequence over this normalized junction model."
    ]
  }
}
