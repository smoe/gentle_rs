{
  "schema": "gentle.gibson_assembly_plan.v1",
  "id": "gibson_destination_first_multi_insert",
  "title": "Destination-first Gibson assembly plan (two inserts)",
  "summary": "Opens a destination vector at a defined site, keeps the destination-derived left and right terminal junctions distinct, and inserts two fragments in a defined order with one internal fragment-fragment junction.",
  "destination": {
    "seq_id": "destination_vector",
    "topology_before_opening": "circular",
    "opening": {
      "mode": "defined_site",
      "label": "vector insertion window",
      "left_end_id": "dest_left",
      "right_end_id": "dest_right",
      "uniqueness_requirement": "must_be_unambiguous"
    }
  },
  "product": {
    "topology": "circular",
    "output_id_hint": "destination_with_insert_x_insert_y"
  },
  "fragments": [
    {
      "id": "insert_x",
      "seq_id": "insert_x_amplicon",
      "role": "insert",
      "orientation": "forward",
      "source_span_1based": {
        "source_seq_id": "donor_construct",
        "start": 101,
        "end": 700
      },
      "left_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_left"
      },
      "right_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_xy"
      }
    },
    {
      "id": "insert_y",
      "seq_id": "insert_y_amplicon",
      "role": "insert",
      "orientation": "forward",
      "source_span_1based": {
        "source_seq_id": "donor_construct",
        "start": 701,
        "end": 1280
      },
      "left_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_xy"
      },
      "right_end_strategy": {
        "mode": "primer_added_overlap",
        "target_junction_id": "junction_right"
      }
    }
  ],
  "assembly_order": [
    {
      "kind": "destination_end",
      "id": "dest_left"
    },
    {
      "kind": "fragment",
      "id": "insert_x"
    },
    {
      "kind": "fragment",
      "id": "insert_y"
    },
    {
      "kind": "destination_end",
      "id": "dest_right"
    }
  ],
  "junctions": [
    {
      "id": "junction_left",
      "left_member": {
        "kind": "destination_end",
        "id": "dest_left"
      },
      "right_member": {
        "kind": "fragment",
        "id": "insert_x"
      },
      "required_overlap_bp": 40,
      "overlap_partition": {
        "left_member_bp": 40,
        "right_member_bp": 0
      },
      "overlap_source": "derive_from_destination_left_flank",
      "distinct_from": [
        "junction_right"
      ]
    },
    {
      "id": "junction_xy",
      "left_member": {
        "kind": "fragment",
        "id": "insert_x"
      },
      "right_member": {
        "kind": "fragment",
        "id": "insert_y"
      },
      "required_overlap_bp": 40,
      "overlap_partition": {
        "left_member_bp": 20,
        "right_member_bp": 20
      },
      "overlap_source": "designed_bridge_sequence",
      "distinct_from": []
    },
    {
      "id": "junction_right",
      "left_member": {
        "kind": "fragment",
        "id": "insert_y"
      },
      "right_member": {
        "kind": "destination_end",
        "id": "dest_right"
      },
      "required_overlap_bp": 40,
      "overlap_partition": {
        "left_member_bp": 0,
        "right_member_bp": 40
      },
      "overlap_source": "derive_from_destination_right_flank",
      "distinct_from": [
        "junction_left"
      ]
    }
  ],
  "validation_policy": {
    "require_unambiguous_destination_opening": true,
    "require_distinct_terminal_junctions": true,
    "adjacency_overlap_mismatch": "error",
    "design_targets": {
      "overlap_bp_min": 40,
      "overlap_bp_max": 100,
      "minimum_overlap_tm_celsius": 60.0
    },
    "uniqueness_checks": {
      "destination_context": "warn",
      "participating_fragments": "warn",
      "reference_contexts": [
        {
          "reference_id": "host_genome",
          "severity": "warn"
        }
      ]
    }
  },
  "derived_design": {
    "junction_overlaps": [
      {
        "junction_id": "junction_left",
        "sequence": null,
        "sequence_source_note": "Derived from the destination left flank at planning time."
      },
      {
        "junction_id": "junction_xy",
        "sequence": null,
        "sequence_source_note": "Designed as an internal bridge overlap and introduced by primer-added overlaps on the adjacent insert ends."
      },
      {
        "junction_id": "junction_right",
        "sequence": null,
        "sequence_source_note": "Derived from the destination right flank at planning time."
      }
    ],
    "primer_design_suggestions": [
      {
        "fragment_id": "insert_x",
        "primer": "forward",
        "pcr_reaction_id": "amplify_insert_x",
        "adds_junction_id": "junction_left",
        "overlap_5prime": {
          "mode": "junction_overlap",
          "length_bp": 40,
          "sequence": null,
          "source_note": "Use the destination left flank as the 5' non-priming overlap segment."
        },
        "priming_3prime": {
          "template_seq_id": "insert_x_amplicon",
          "orientation": "forward",
          "source_note": "Choose the gene-specific 3' priming segment from the insert_x template."
        }
      },
      {
        "fragment_id": "insert_x",
        "primer": "reverse",
        "pcr_reaction_id": "amplify_insert_x",
        "adds_junction_id": "junction_xy",
        "overlap_5prime": {
          "mode": "junction_overlap",
          "length_bp": 40,
          "sequence": null,
          "source_note": "Add the designed internal bridge overlap as the 5' non-priming segment of the reverse primer for insert_x; the junction is modeled as a 20/20 split across the two adjacent members."
        },
        "priming_3prime": {
          "template_seq_id": "insert_x_amplicon",
          "orientation": "reverse_complement",
          "source_note": "Choose the gene-specific 3' priming segment from insert_x on the reverse-complement strand."
        }
      },
      {
        "fragment_id": "insert_y",
        "primer": "forward",
        "pcr_reaction_id": "amplify_insert_y",
        "adds_junction_id": "junction_xy",
        "overlap_5prime": {
          "mode": "junction_overlap",
          "length_bp": 40,
          "sequence": null,
          "source_note": "Add the same designed internal bridge overlap as the 5' non-priming segment of the forward primer for insert_y; the junction is modeled as a 20/20 split across the two adjacent members."
        },
        "priming_3prime": {
          "template_seq_id": "insert_y_amplicon",
          "orientation": "forward",
          "source_note": "Choose the gene-specific 3' priming segment from the insert_y template."
        }
      },
      {
        "fragment_id": "insert_y",
        "primer": "reverse",
        "pcr_reaction_id": "amplify_insert_y",
        "adds_junction_id": "junction_right",
        "overlap_5prime": {
          "mode": "junction_overlap",
          "length_bp": 40,
          "sequence": null,
          "source_note": "Use the reverse complement of the destination right flank as the 5' non-priming overlap segment."
        },
        "priming_3prime": {
          "template_seq_id": "insert_y_amplicon",
          "orientation": "reverse_complement",
          "source_note": "Choose the gene-specific 3' priming segment from insert_y on the reverse-complement strand."
        }
      }
    ],
    "assembly_setup_advisories": [
      {
        "kind": "pcr_cleanup",
        "severity": "warn",
        "note": "For assemblies of three or more PCR fragments, column purification is recommended before Gibson assembly."
      },
      {
        "kind": "fragment_stoichiometry",
        "severity": "warn",
        "note": "Use approximately equimolar fragment amounts for multi-fragment vector assemblies."
      }
    ],
    "notes": [
      "This multi-fragment example uses 40 bp overlaps as a practical starting point for a three-fragment Gibson assembly.",
      "This example preserves source order from donor_construct by placing the lower bp fragment first.",
      "The internal junction_xy overlap is modeled as a split overlap across the two adjacent inserts rather than as a one-sided overlap.",
      "The two primers that implement the internal junction_xy overlap belong to separate PCR reactions, one for insert_x and one for insert_y.",
      "Multi-fragment cartoons can be derived from the same adjacency chain by rendering one event sequence over this normalized junction model."
    ]
  }
}
