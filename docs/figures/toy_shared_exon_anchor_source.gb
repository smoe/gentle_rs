                     /mol_type="genomic DNA"
     gene            1..150
                     /gene="ANCHOR_TOY"
                     /label="ANCHOR_TOY"
                     /note="Synthetic four-exon teaching locus for anchored
                     overlay dotplots"
     exon            1..24
                     /label="E1"
     exon            43..66
                     /label="E2"
     exon            85..108
                     /label="E3 shared"
                     /note="Shared exon used as the anchored x-axis reference"
     exon            127..150
                     /label="E4"
     mRNA            join(1..24,43..66,85..108,127..150)
                     /gene="ANCHOR_TOY"
                     /transcript_id="TOYTX1"
                     /label="Toy longest"
                     /note="Four-exon baseline transcript"
     mRNA            join(43..66,85..108,127..150)
                     /gene="ANCHOR_TOY"
                     /transcript_id="TOYTX2"
