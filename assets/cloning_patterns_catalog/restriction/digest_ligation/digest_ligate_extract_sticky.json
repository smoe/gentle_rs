{
  "schema": "gentle.cloning_pattern_template.v1",
  "name": "digest_ligate_extract_sticky",
  "description": "Digest one sequence with two enzymes, ligate two selected fragments (sticky protocol), and extract one region from the first ligation product.",
  "details_url": "https://www.addgene.org/protocols/restriction-digest/",
  "parameters": [
    {
      "name": "seq_id",
      "required": true
    },
    {
      "name": "enzyme_a",
      "default_value": "BamHI",
      "required": false
    },
    {
      "name": "enzyme_b",
      "default_value": "EcoRI",
      "required": false
    },
    {
      "name": "digest_prefix",
      "default_value": "digest",
      "required": false
    },
    {
      "name": "left_fragment",
      "default_value": "1",
      "required": false
    },
    {
      "name": "right_fragment",
      "default_value": "2",
      "required": false
    },
    {
      "name": "ligation_prefix",
      "default_value": "ligation",
      "required": false
    },
    {
      "name": "extract_from",
      "default_value": "0",
      "required": false
    },
    {
      "name": "extract_to",
      "default_value": "300",
      "required": false
    },
    {
      "name": "output_id",
      "default_value": "ligated_extract",
      "required": false
    }
  ],
  "input_ports": [
    {
      "port_id": "seq_id",
      "kind": "sequence",
      "required": true,
      "cardinality": "one",
      "description": "Input sequence to digest."
    },
    {
      "port_id": "enzyme_a",
      "kind": "string",
      "required": true,
      "cardinality": "one",
      "description": "Primary restriction enzyme name."
    },
    {
      "port_id": "enzyme_b",
      "kind": "string",
      "required": true,
      "cardinality": "one",
      "description": "Secondary restriction enzyme name."
    },
    {
      "port_id": "left_fragment",
      "kind": "number",
      "required": false,
      "cardinality": "one",
      "description": "1-based digest fragment index for ligation left input."
    },
    {
      "port_id": "right_fragment",
      "kind": "number",
      "required": false,
      "cardinality": "one",
      "description": "1-based digest fragment index for ligation right input."
    },
    {
      "port_id": "extract_from",
      "kind": "number",
      "required": false,
      "cardinality": "one",
      "description": "Extract start coordinate from first ligation product."
    },
    {
      "port_id": "extract_to",
      "kind": "number",
      "required": false,
      "cardinality": "one",
      "description": "Extract end coordinate from first ligation product."
    }
  ],
  "output_ports": [
    {
      "port_id": "digest_prefix",
      "kind": "sequence",
      "required": false,
      "cardinality": "many",
      "description": "Digest product prefix namespace."
    },
    {
      "port_id": "ligation_prefix",
      "kind": "sequence",
      "required": false,
      "cardinality": "many",
      "description": "Ligation product prefix namespace."
    },
    {
      "port_id": "output_id",
      "kind": "sequence",
      "required": false,
      "cardinality": "one",
      "description": "Extracted ligation product sequence ID."
    }
  ],
  "script": "op {\"Digest\":{\"input\":\"${seq_id}\",\"enzymes\":[\"${enzyme_a}\",\"${enzyme_b}\"],\"output_prefix\":\"${digest_prefix}\"}}\nop {\"Ligation\":{\"inputs\":[\"${digest_prefix}_${left_fragment}\",\"${digest_prefix}_${right_fragment}\"],\"circularize_if_possible\":false,\"output_id\":null,\"protocol\":\"Sticky\",\"output_prefix\":\"${ligation_prefix}\",\"unique\":false}}\nop {\"ExtractRegion\":{\"input\":\"${ligation_prefix}_1\",\"from\":${extract_from},\"to\":${extract_to},\"output_id\":\"${output_id}\"}}"
}
