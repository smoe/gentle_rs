{
  "schema": "gentle.clawbio_experimental_followup_request_catalog.v1",
  "description": "Machine-readable ClawBio routing catalog for turning biological observations into GENtle-backed experimental follow-up and perturbation-planning requests.",
  "skill_alias": "gentle-cloning",
  "skill_info_request": "skills/gentle-cloning/examples/request_skill_info.json",
  "planning_axes": [
    "estimated_time_hours",
    "estimated_cost",
    "local_fit_score",
    "composite_meta_score",
    "guardrail_status",
    "missing_material_classes",
    "procurement_delay"
  ],
  "intents": [
    {
      "intent_id": "snp_effect",
      "title": "Determine SNP or small-variant effect",
      "detection_phrases": [
        "determine the effect of this SNP",
        "what does this rsID do",
        "follow up this variant",
        "design an assay for this SNP",
        "test this regulatory variant"
      ],
      "evidence_classes": [
        "variant_context",
        "regulatory_context",
        "splice_isoform_context",
        "protein_context"
      ],
      "required_user_inputs": [
        "variant_id_or_coordinate"
      ],
      "optional_user_inputs": [
        "genome_build",
        "target_gene",
        "cell_model",
        "desired_readout"
      ],
      "external_evidence": [
        "VEP or equivalent transcript consequence",
        "SpliceAI or equivalent splice predictor when splice proximity is plausible",
        "SIFT/PolyPhen/AlphaMissense-like coding predictors for coding variants",
        "RegulomeDB/eQTL/ENCODE-style regulatory context when available",
        "ClinVar/gnomAD/pharmacogenomic/literature context when relevant"
      ],
      "gentle_requests": [
        {
          "path": "skills/gentle-cloning/examples/request_skill_info.json",
          "purpose": "Confirm copied skill metadata before deeper orchestration.",
          "requires_adaptation": false
        },
        {
          "path": "skills/gentle-cloning/examples/request_dbsnp_fetch_rs9923231.json",
          "purpose": "Fetch and annotate a local sequence context for the user's rsID.",
          "requires_adaptation": true
        },
        {
          "path": "skills/gentle-cloning/examples/request_export_sequence_context_bundle_rs9923231_vkorc1.json",
          "purpose": "Export compact context JSON/text, BED, and graphics for the fetched locus.",
          "requires_adaptation": true
        },
        {
          "path": "skills/gentle-cloning/examples/request_workflow_vkorc1_planning.json",
          "purpose": "Use the promoter-reporter planning workflow when the variant is regulatory/promoter-proximal.",
          "requires_adaptation": true
        }
      ],
      "gentle_shell_commands": [
        {
          "shell_line": "routines list --query reporter",
          "purpose": "Discover reporter-oriented routine families before proposing wet-lab follow-up.",
          "confirmation": "not_required"
        },
        {
          "shell_line": "routines list --query expression",
          "purpose": "Search the routine catalog for expression-oriented construct routes.",
          "confirmation": "not_required"
        }
      ],
      "followup_families": [
        "promoter_luciferase_reporter",
        "UTR_or_translation_reporter",
        "minigene_splicing_reporter",
        "allele_paired_overexpression",
        "endogenous_editing"
      ],
      "confirmation_gates": [
        "external_predictor_calls",
        "reference_preparation",
        "multi_step_graphical_workflow",
        "genome_editing_strategy_selection"
      ]
    },
    {
