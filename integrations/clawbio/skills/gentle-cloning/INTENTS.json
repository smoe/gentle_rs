{
  "schema": "clawbio.skill_intents.v1",
  "skill": "gentle-cloning",
  "aliases": [
    "gentle",
    "GENtle",
    "gentle cloning",
    "gentle-cloning",
    "cloning"
  ],
  "routes": [
