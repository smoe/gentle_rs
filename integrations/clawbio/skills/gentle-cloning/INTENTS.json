      "intent_id": "skill_info",
      "description": "Report GENtle ClawBio skill metadata without requiring a GENtle runtime.",
      "trigger_terms": [
        "skill info",
        "skill metadata",
        "what can gentle do",
        "gentle skill"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_skill_info.json"
        }
      ]
    },
    {
      "intent_id": "capabilities",
      "description": "Ask the installed GENtle runtime for its deterministic capability surface.",
      "trigger_terms": [
        "capabilities",
        "available operations",
        "what operations",
        "what commands"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_capabilities.json"
        }
      ]
    },
    {
      "intent_id": "runtime_version",
      "description": "Check the installed GENtle runtime version through the ClawBio skill bundle.",
      "trigger_terms": [
        "version",
        "runtime version",
        "installed version",
        "installed gentle",
        "gentle runtime"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_runtime_version.json"
        }
      ]
    },
    {
      "intent_id": "services_status",
      "description": "Check which GENtle services, references, helpers, and local resources are ready.",
      "trigger_terms": [
        "services status",
        "service status",
        "services",
        "readiness",
        "ready",
        "local resources",
        "resources are ready"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_services_status.json"
        }
      ]
    },
    {
      "intent_id": "resources_status",
      "description": "Check GENtle external resource and installed database readiness.",
      "trigger_terms": [
        "resources status",
        "resource status",
        "resources",
        "databases",
        "installed databases",
        "jaspar",
        "rebase",
        "attract"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_resources_status.json"
        }
      ]
    },
    {
      "intent_id": "demo_isoform_protein_gel",
      "description": "Run the canonical offline isoform protein molecular-weight gel demo using the bundled example locus.",
      "trigger_terms": [
        "protein gel demo",
        "isoform protein gel demo",
        "molecular weight gel demo"
      ],
      "demo_policy": "only_when_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_workflow_isoform_protein_gel_demo.json"
        }
      ]
    },
    {
      "intent_id": "demo_isoform_protein_2d_gel",
      "description": "Run the canonical offline protein pI-vs-kDa 2D gel demo using the bundled example locus.",
      "trigger_terms": [
        "protein 2d gel demo",
        "isoform protein 2d gel demo",
        "isoelectric point demo",
        "pi vs kda demo"
      ],
      "demo_policy": "only_when_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_workflow_isoform_protein_2d_gel_demo.json"
        }
      ]
    },
    {
      "intent_id": "ensembl_gene_panel_protein_gel",
      "description": "Render the guide-ready PATZ1/TP73/TP53/TP63/SP1/BACH2 Ensembl isoform molecular-weight gel.",
      "trigger_terms": [
        "gene panel protein gel",
        "multi gene protein gel",
        "1d protein gel",
        "molecular weight isoform panel",
        "PATZ1 TP73 TP53 TP63 SP1 BACH2",
        "PATZ1 TP73 TP53 TP63 SP1 BACH2 protein gel"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_workflow_gene_panel_isoform_protein_gel_ensembl.json"
        }
      ]
    },
    {
      "intent_id": "ensembl_gene_protein_2d_gel",
      "description": "Render a protein pI-vs-kDa 2D gel for a requested Ensembl gene symbol.",
      "trigger_terms": [
        "2d protein gel",
        "protein 2d gel",
        "gene protein 2d gel",
        "ensembl protein 2d gel",
        "ensembl gene protein 2d gel",
        "isoforms from ensembl",
        "from ensembl"
      ],
      "demo_policy": "never_unless_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "slots": {
            "gene_symbol": {
              "required": true
            },
            "species": {
              "required": false,
              "default": "homo_sapiens",
              "aliases": {
                "human": "homo_sapiens",
                "homo sapiens": "homo_sapiens"
              }
            },
            "source": {
              "required": false,
              "default": "ensembl",
              "choices": [
                "ensembl"
              ]
            }
          },
          "input_template": {
            "schema": "gentle.clawbio_skill_request.v1",
            "mode": "gene-protein-2d-gel",
            "state_path": ".gentle_state.json",
            "source": "{source}",
            "species": "{species}",
            "gene_symbol": "{gene_symbol}",
            "ladders": [
              "Protein Ladder 10-100 kDa"
            ],
            "timeout_secs": 600
          }
        }
      ]
    },
    {
      "intent_id": "demo_ensembl_gene_protein_2d_gel",
      "description": "Run an online Ensembl gene protein pI-vs-kDa 2D gel example using the parameterized gene-protein-2d-gel request mode.",
      "trigger_terms": [
        "ensembl gene protein 2d gel demo",
        "gene protein 2d gel demo",
        "parameterized protein 2d gel demo"
      ],
      "demo_policy": "only_when_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_gene_protein_2d_gel_ensembl_demo.json"
        }
      ]
    },
    {
      "intent_id": "demo_trypsin_digest_gel",
      "description": "Run the canonical offline trypsin digest gel demo using the bundled example locus.",
      "trigger_terms": [
        "trypsin digest gel demo",
        "protease digest demo",
        "peptide gel demo"
      ],
      "demo_policy": "only_when_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "input": "examples/request_workflow_trypsin_digest_gel_demo.json"
        }
      ]
    },
    {
      "intent_id": "explicit_demo",
      "description": "Run the explicit GENtle ClawBio demo when the user asks for a demo.",
      "trigger_terms": [
        "gentle demo",
        "cloning demo",
        "demo",
        "demonstration",
        "example"
      ],
      "demo_policy": "only_when_explicit",
      "plan": [
        {
          "kind": "skill_run",
          "skill": "gentle-cloning",
          "demo": true
        }
      ]
    }
  ]
