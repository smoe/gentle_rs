{
  "name": "gentle-cloning",
  "cli_alias": "gentle-cloning",
  "description": "Deterministic sequence-design and genome-context specialist powered by GENtle, positioned to turn cohort or patient-data observations, differential-expression hits, splice-variant observations, perturbation requests, or direct DNA fragment requests into sequence-grounded mechanistic follow-up, stateless inspection, installed-runtime and resource-readiness checks including ViennaRNA/RNAfold and rnapkin executable resources, reproducible assay-planning artifacts, the full shared PCR/qPCR command family for ClawBio (Primer3 preflight, seed helpers, PCR primer design, probe-based qPCR/TaqMan design, cDNA PCR/qPCR assay tests, report listing/inspection/export, PCR protocol cartoons, restriction-cloning PCR handoffs, and assistant-ready wet-lab handoff exports), transcript qPCR panel tables with shared reverse/probe and characteristic forward primers, transcript-native protein-residue-to-genomic-codon mapping reports, reusable local reference assets, and transcript-native protein-gel / protein 2D-gel / protease-digest figures for bundled example loci, parameterized Ensembl genes, and Ensembl gene panels. Ships a ClawBio skill-intent descriptor for runner-neutral chat routing.",
  "version": "0.1.0",
  "status": "mvp",
  "has_script": true,
  "has_tests": true,
  "has_demo": true,
  "demo_command": "python clawbio.py run gentle-cloning --demo",
  "dependencies": [
    "python3",
    "Configured GENTLE_CLI_CMD (for example gentle_local_checkout_cli.sh or gentle_apptainer_cli.sh)",
    "gentle_cli on PATH or explicit --gentle-cli",
    "ViennaRNA RNAfold on PATH or explicit GENTLE_RNAFOLD_BIN for RNA secondary-structure folding",
    "rnapkin on PATH or explicit GENTLE_RNAPKIN_BIN for RNA secondary-structure rendering",
    "cargo run --quiet --bin gentle_cli -- (developer fallback)"
  ],
