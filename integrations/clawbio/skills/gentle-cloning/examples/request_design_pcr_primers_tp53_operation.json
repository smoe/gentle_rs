        "max_anneal_hits": 1
      },
      "reverse": {
        "min_length": 18,
        "max_length": 24,
        "start_0based": 340,
        "end_0based": 430,
        "min_tm_c": 55.0,
        "max_tm_c": 68.0,
        "min_gc_fraction": 0.35,
        "max_gc_fraction": 0.7,
        "max_anneal_hits": 1
      },
      "pair_constraints": {
        "require_roi_flanking": true
